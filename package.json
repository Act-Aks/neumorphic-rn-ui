{
  "name": "@act-aks/neumorphic-rn-ui",
  "version": "1.0.0",
  "description": "Neumorphic UI component library for React Native",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "lib"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "bob build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install && bob build"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@niibase/uniwind": "1.6.0",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-native-async-storage/expo-with-async-storage": "1.0.0",
    "expo": "55.0.9",
    "expo-constants": "55.0.9",
    "expo-linking": "55.0.9",
    "expo-router": "55.0.8",
    "expo-status-bar": "55.0.4",
    "react": "19.2.4",
    "react-native": "0.83.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.24.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.2.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "tailwind-variants": "*",
    "tailwindcss": "*",
    "@niibase/uniwind": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "conventional-changelog-conventionalcommits": "8.0.0",
    "@types/react": "19.2.14",
    "lefthook": "2.1.4",
    "lint-staged": "16.4.0",
    "react-native-builder-bob": "0.40.18",
    "semantic-release": "24.2.5",
    "typescript": "6.0.2",
    "ultracite": "7.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/act-aks/neumorphic-rn-ui.git"
  },
  "bugs": {
    "url": "https://github.com/act-aks/neumorphic-rn-ui/issues"
  },
  "homepage": "https://github.com/act-aks/neumorphic-rn-ui#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
